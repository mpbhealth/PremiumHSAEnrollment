
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Password Encryption Key (for advisor password encryption)
# IMPORTANT: Keep this key secure and never share it
# Generate a strong random key and add it to your .env file
VITE_ENCRYPTION_SECRET_KEY=your_secret_encryption_key_here

# RSA-2048 public key for client-side payload encryption (base64 SPKI DER)
# The matching RSA_PRIVATE_KEY must be set as a Supabase Edge Function secret
VITE_RSA_PUBLIC_KEY=your_rsa_public_key_base64_here

# 1enrollment.com API Credentials (used in Edge Function)
ENROLLMENT_API_USERNAME=your_username
ENROLLMENT_API_PASSWORD=your_password
ENROLLMENT_BROKER_ID=your_broker_id
